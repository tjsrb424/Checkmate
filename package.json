{
  "name": "oetongsu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "opening:build": "tsx scripts/build-opening-book.ts",
    "opening:inspect": "tsx scripts/inspect-opening-book.ts",
    "opening:test-build": "tsx scripts/build-opening-book.ts --input data/fixtures/opening-records.sample.csv --output data/opening-book/opening-book.sample.json --summary data/opening-book/opening-book-summary.sample.json",
    "arena:league": "tsx scripts/run-arena-league.ts",
    "arena:league:quick": "tsx scripts/run-arena-league.ts --quick",
    "beta:check": "tsx scripts/check-beta-readiness.ts",
    "beta:check:strict": "tsx scripts/check-beta-readiness.ts --strict",
    "data:convert-raw-records": "tsx scripts/convert-raw-janggi-records.ts",
    "data:validate-records": "tsx scripts/validate-training-records.ts",
    "data:inspect-records": "tsx scripts/inspect-training-records.ts",
    "training:server": "node scripts/run-training-server.cjs",
    "training:server:dev": "node scripts/run-training-server.cjs --reload",
    "ml:test": "node scripts/run-ml-tests.cjs",
    "ml:progress": "cd ml && python -m oetongsu_ml.progress_viewer",
    "ml:progress:watch": "cd ml && python -m oetongsu_ml.progress_viewer --watch",
    "ml:export-policy": "tsx scripts/export-policy-data.ts",
    "ml:export-policy:sample": "tsx scripts/export-policy-data.ts --input data/fixtures/opening-records.sample.csv --output data/ml/policy_samples.sample.jsonl --summary data/ml/policy_samples_summary.sample.json",
    "ml:export-value": "tsx scripts/export-value-data.ts",
    "ml:export-value:sample": "tsx scripts/export-value-data.ts --input data/fixtures/opening-records.sample.csv --output data/ml/value_samples.sample.jsonl --summary data/ml/value_samples_summary.sample.json",
    "ml:export-az-supervised": "tsx scripts/export-az-supervised-data.ts",
    "ml:export-az-supervised:sample": "tsx scripts/export-az-supervised-data.ts --input data/fixtures/opening-records.sample.csv --output data/ml/az_supervised_samples.sample.jsonl --summary data/ml/az_supervised_summary.sample.json",
    "ml:selfplay:quick": "node scripts/run-self-play.cjs --games 1 --maxPlies 4 --simulations 4 --randomModel",
    "ml:selfplay:parallel:quick": "node scripts/run-parallel-self-play.cjs --games 2 --workers 2 --simulations 2 --maxPlies 4 --randomModel",
    "ml:az:quick": "node scripts/run-az-training.cjs --games 1 --maxPlies 4 --simulations 4 --epochs 1 --batchSize 2 --channels 8",
    "ml:model-arena:quick": "node scripts/promote-model.cjs --randomModel --games 2 --maxPlies 4 --simulations 2 --version random_candidate_quick",
    "ml:autotrain:quick": "node scripts/run-autotrain.cjs --quick",
    "ml:bootstrap-champion": "node scripts/bootstrap-champion.cjs",
    "ml:bootstrap-champion:sample": "node scripts/bootstrap-champion.cjs --data ../data/ml/az_supervised_samples.sample.jsonl --output ../data/models/checkpoints/supervised_sample.pt --version supervised_sample --epochs 1 --batchSize 2 --channels 4 --overwrite",
    "ml:rules:quick": "node scripts/run-ml-tests.cjs tests/test_python_rules_repetition.py tests/test_python_perft.py"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "jsdom": "^25.0.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
