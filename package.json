{
  "name": "oetongsu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "opening:build": "tsx scripts/build-opening-book.ts",
    "opening:inspect": "tsx scripts/inspect-opening-book.ts",
    "opening:test-build": "tsx scripts/build-opening-book.ts --input data/fixtures/opening-records.sample.csv --output data/opening-book/opening-book.sample.json --summary data/opening-book/opening-book-summary.sample.json",
    "arena:league": "tsx scripts/run-arena-league.ts",
    "arena:league:quick": "tsx scripts/run-arena-league.ts --quick",
    "beta:check": "tsx scripts/check-beta-readiness.ts",
    "beta:check:strict": "tsx scripts/check-beta-readiness.ts --strict",
    "ml:test": "node scripts/run-ml-tests.cjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "jsdom": "^25.0.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
